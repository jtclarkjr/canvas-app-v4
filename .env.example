SUPABASE_URL=http://localhost:54321
SUPABASE_SECRET_KEY=<your-secret-key>

# Browser client (VITE_ prefix exposes to client bundle)
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_PUBLISHABLE_KEY=<your-publishable-key>

# Optional: OAuth provider buttons (configure providers in Supabase dashboard)
# Set to "true" to show the corresponding sign-in button
ENABLE_GITHUB_AUTH=false
ENABLE_GOOGLE_AUTH=false
ENABLE_APPLE_AUTH=false
